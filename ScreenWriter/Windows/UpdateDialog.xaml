<Window x:Class="ScreenWriter.Windows.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="440" Height="360"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Icon="pack://application:,,,/ScreenWriter;component/Assets/icon.ico"
        Title="{DynamicResource Str_UpdateAvailable}">

    <Window.Resources>
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#4B5563"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="26"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FF6B6B"/>
                                <Setter Property="Foreground" Value="#FF6B6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#06D6A0"/>
            <Setter Property="Foreground"      Value="#111827"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20E5B4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#374151"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="18,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#14FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="#FF111827"
            BorderBrush="#2806D6A0" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#000000" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <Rectangle Height="2" VerticalAlignment="Top">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#06D6A0" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Button Content="✕" Style="{StaticResource CloseBtn}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,12,0" FontSize="12"
                    Click="BtnClose_Click"/>

            <StackPanel VerticalAlignment="Center" Margin="32,24,32,24">

                <TextBlock Text="{DynamicResource Str_UpdateAvailable}"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,8,0,14"/>

                <Grid HorizontalAlignment="Center" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Str_CurrentVersion}"
                                   FontSize="11" Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtCurrent"
                                   FontSize="16" Foreground="#9CA3AF"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{DynamicResource Str_Arrow}"
                               FontSize="18" Foreground="#06D6A0"
                               VerticalAlignment="Bottom" Margin="0,0,0,4"/>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource Str_NewVersion}"
                                   FontSize="11" Foreground="#06D6A0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtLatest"
                                   FontSize="16" Foreground="#06D6A0"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <Border Background="#0A000000" CornerRadius="8" Padding="12,10"
                        Margin="0,0,0,18" MaxHeight="90">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtNotes"
                                   FontSize="12" Foreground="#9CA3AF"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>

                <StackPanel x:Name="PanelButtons" Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Content="{DynamicResource Str_UpdateNow}"
                            Style="{StaticResource PrimaryBtn}"
                            Click="BtnUpdate_Click" Margin="0,0,10,0"/>
                    <Button Content="{DynamicResource Str_Later}"
                            Style="{StaticResource SecondaryBtn}"
                            Click="BtnClose_Click"/>
                </StackPanel>

                <StackPanel x:Name="PanelProgress" Visibility="Collapsed">
                    <TextBlock x:Name="TxtProgress"
                               Text="{DynamicResource Str_Downloading}"
                               FontSize="12" Foreground="#9CA3AF"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <ProgressBar x:Name="Progress" Height="6" Minimum="0" Maximum="100"
                                 Background="#1F2937" Foreground="#06D6A0"
                                 BorderThickness="0"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</Window>
