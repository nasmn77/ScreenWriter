<Window x:Class="ScreenWriter.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="380" Height="310"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        Icon="/Assets/icon.ico"
        Title="عن البرنامج">

    <Window.Resources>
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#4B5563"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="26"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FF6B6B"/>
                                <Setter Property="Foreground" Value="#FF6B6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="#FF111827"
            BorderBrush="#2806D6A0" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#000000" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <!-- Accent glow line at top -->
            <Rectangle Height="2" VerticalAlignment="Top">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#06D6A0" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Close button -->
            <Button Content="✕" Style="{StaticResource CloseBtn}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,12,0" FontSize="12"
                    Click="BtnClose_Click"/>

            <!-- Main content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="32,10,32,10">

                <!-- App Icon -->
                <Image x:Name="AppIcon" Width="68" Height="68"
                       HorizontalAlignment="Center" Margin="0,0,0,14"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- App Name -->
                <TextBlock Text="Screen Writer" FontSize="24" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>

                <!-- Version badge -->
                <Border HorizontalAlignment="Center" Margin="0,6,0,14"
                        Background="#0D06D6A0" CornerRadius="10"
                        BorderBrush="#3006D6A0" BorderThickness="1"
                        Padding="12,3">
                    <TextBlock Text="الإصدار  1.0.0"
                               FontSize="12" Foreground="#06D6A0"
                               HorizontalAlignment="Center"
                               FlowDirection="RightToLeft"/>
                </Border>

                <!-- Description -->
                <TextBlock Text="تطبيق رسم وتوضيح فوق الشاشة"
                           FontSize="13" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           FlowDirection="RightToLeft"/>

                <!-- Divider -->
                <Rectangle Height="1" Fill="#14FFFFFF" Margin="0,16,0,14"/>

                <!-- Author row -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="ناصر الماضي" Foreground="#D1D5DB"
                               FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBlock Text=":المطوّر" Foreground="#6B7280"
                               FontSize="12" FlowDirection="RightToLeft"/>
                </StackPanel>

                <!-- Email -->
                <TextBlock Text="nasmn77@gmail.com"
                           FontSize="11" Foreground="#4B9EBF"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>

                <!-- Copyright -->
                <TextBlock Text="Copyright © 2026 ناصر الماضي"
                           FontSize="11" Foreground="#374151"
                           HorizontalAlignment="Center" Margin="0,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
