<Window x:Class="ScreenWriter.Windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="420" Height="250"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True">

    <Border x:Name="RootBorder" Opacity="0" CornerRadius="16"
            Background="#FF111827"
            BorderBrush="#3006D6A0" BorderThickness="1">

        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#000000" Opacity="0.8"/>
        </Border.Effect>

        <Grid>
            <!-- Accent glow line at top -->
            <Rectangle Height="2" VerticalAlignment="Top">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#06D6A0" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Main content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30,0">

                <!-- App Icon -->
                <Image x:Name="AppIcon" Width="56" Height="56"
                       HorizontalAlignment="Center" Margin="0,0,0,14"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- App Name -->
                <TextBlock Text="Screen Writer" FontSize="28" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>

                <!-- Tagline -->
                <TextBlock Text="{DynamicResource Str_SplashTagline}"
                           FontSize="13" Foreground="#6B7280"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>

                <!-- Animated loading dots -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                    <Ellipse Width="7" Height="7" Fill="#06D6A0" Margin="5,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.12" Duration="0:0:0.55"
                                                         AutoReverse="True" BeginTime="0:0:0"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="7" Height="7" Fill="#06D6A0" Margin="5,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.12" Duration="0:0:0.55"
                                                         AutoReverse="True" BeginTime="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="7" Height="7" Fill="#06D6A0" Margin="5,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.12" Duration="0:0:0.55"
                                                         AutoReverse="True" BeginTime="0:0:0.36"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </StackPanel>
            </StackPanel>

            <!-- Version + author at bottom -->
            <TextBlock x:Name="TxtVersionLine"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center"
                       Margin="0,0,0,14"
                       FontSize="11" Foreground="#374151"/>
        </Grid>
    </Border>
</Window>
