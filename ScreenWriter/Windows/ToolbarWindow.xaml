<Window x:Class="ScreenWriter.Windows.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Left="0" Top="0"
        Icon="/Assets/icon.ico"
        Title="Screen Writer Toolbar"
        MouseEnter="Toolbar_MouseEnter"
        MouseLeave="Toolbar_MouseLeave">

    <Window.Resources>
        <Style x:Key="ColorBtn" TargetType="Button">
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Width="18" Height="18"
                                 Fill="{TemplateBinding Background}"
                                 Stroke="{TemplateBinding BorderBrush}"
                                 StrokeThickness="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="MinWidth"        Value="30"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Padding"         Value="4,0"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#E0111827" CornerRadius="0,0,12,0" Padding="10,7">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- تفعيل/إيقاف -->
            <Button x:Name="BtnToggleMode" Style="{StaticResource ToolBtn}" Padding="8,0"
                    Click="BtnToggleMode_Click" ToolTip="تفعيل / إيقاف الرسم  (Ctrl+Alt+D)">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ModeIndicator" Width="8" Height="8" Fill="#555555" Margin="0,0,5,0"/>
                    <TextBlock x:Name="ModeText" Text="رسم" FontSize="12"
                               Foreground="#CCCCCC" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Rectangle Width="1" Height="26" Fill="#44FFFFFF" Margin="6,0"/>

            <!-- ألوان -->
            <Button Background="#E63946" Style="{StaticResource ColorBtn}" Tag="#E63946" Click="ColorBtn_Click" ToolTip="أحمر"/>
            <Button Background="#F4A261" Style="{StaticResource ColorBtn}" Tag="#F4A261" Click="ColorBtn_Click" ToolTip="برتقالي"/>
            <Button Background="#FFD166" Style="{StaticResource ColorBtn}" Tag="#FFD166" Click="ColorBtn_Click" ToolTip="أصفر"/>
            <Button Background="#06D6A0" Style="{StaticResource ColorBtn}" Tag="#06D6A0" Click="ColorBtn_Click" ToolTip="أخضر"/>
            <Button Background="#118AB2" Style="{StaticResource ColorBtn}" Tag="#118AB2" Click="ColorBtn_Click" ToolTip="أزرق"/>
            <Button Background="#8338EC" Style="{StaticResource ColorBtn}" Tag="#8338EC" Click="ColorBtn_Click" ToolTip="بنفسجي"/>
            <Button Background="#FFFFFF" Style="{StaticResource ColorBtn}" Tag="#FFFFFF" Click="ColorBtn_Click" ToolTip="أبيض"/>
            <Button Background="#111111" Style="{StaticResource ColorBtn}" Tag="#111111" Click="ColorBtn_Click" ToolTip="أسود"/>

            <Rectangle Width="1" Height="26" Fill="#44FFFFFF" Margin="6,0"/>

            <!-- حجم القلم -->
            <TextBlock Text="✏" Foreground="#888" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Slider x:Name="SizeSlider" Width="65" Minimum="2" Maximum="30" Value="4"
                    VerticalAlignment="Center" ValueChanged="SizeSlider_ValueChanged"/>

            <Rectangle Width="1" Height="26" Fill="#44FFFFFF" Margin="6,0"/>

            <!-- أدوات الرسم -->
            <Button x:Name="BtnPen"     Content="🖊"  Style="{StaticResource ToolBtn}" Click="BtnPen_Click"     ToolTip="رسم حر"/>
            <Button x:Name="BtnLine"    Content="╱"   Style="{StaticResource ToolBtn}" Click="BtnLine_Click"    ToolTip="خط مستقيم"/>
            <Button x:Name="BtnRect"    Content="▭"   Style="{StaticResource ToolBtn}" Click="BtnRect_Click"    ToolTip="مستطيل"/>
            <Button x:Name="BtnEllipse" Content="⬭"   Style="{StaticResource ToolBtn}" Click="BtnEllipse_Click" ToolTip="دائرة / بيضاوي"/>
            <Button x:Name="BtnText"    Content="T"   Style="{StaticResource ToolBtn}" Click="BtnText_Click"    ToolTip="كتابة نص" FontWeight="Bold"/>
            <Button x:Name="BtnEraser"  Content="⌫"   Style="{StaticResource ToolBtn}" Click="BtnEraser_Click"  ToolTip="ممحاة"/>

            <Rectangle Width="1" Height="26" Fill="#44FFFFFF" Margin="6,0"/>

            <!-- تراجع / إعادة / مسح -->
            <Button Content="↩" Style="{StaticResource ToolBtn}" Click="BtnUndo_Click"  ToolTip="تراجع"/>
            <Button Content="↪" Style="{StaticResource ToolBtn}" Click="BtnRedo_Click"  ToolTip="إعادة"/>
            <Button Content="🗑" Style="{StaticResource ToolBtn}" Click="BtnClear_Click" ToolTip="مسح الكل"/>

            <Rectangle Width="1" Height="26" Fill="#44FFFFFF" Margin="6,0"/>

            <!-- إغلاق -->
            <Button Content="✕" Style="{StaticResource ToolBtn}" Click="BtnClose_Click"
                    Foreground="#FF6B6B" ToolTip="إغلاق التطبيق" Padding="6,0"/>

        </StackPanel>
    </Border>
</Window>
